---
export interface Props { includePicnic: boolean }
const { includePicnic } = Astro.props;
---
<section class="section relative">
  <div class="container-wide">
    <div class="text-center reveal">
      <p class="eyebrow">Программа</p>
      <h2 class="mt-4 text-5xl md:text-7xl font-display">Два акта <span class="serif-italic text-terracotta">одной</span> истории</h2>
    </div>

    <div class={`mt-20 grid gap-10 ${includePicnic ? 'md:grid-cols-2' : 'md:grid-cols-1 max-w-2xl mx-auto'}`}>
      <!-- ACT I -->
      <article class="relative overflow-hidden reveal vintage-border bg-gradient-to-br from-[#F4E5D0] via-paper to-[#EED9BE] p-10 md:p-14">
        <div class="grain"></div>
        <div class="relative">
          <div class="flex items-baseline justify-between">
            <span class="font-mono text-xs tracking-editorial uppercase text-clay">Актъ первый</span>
            <span class="font-mono text-xs tracking-editorial uppercase text-muted">19 · 09</span>
          </div>
          <div class="mt-6 flex items-start gap-6">
            <span class="font-display serif-italic text-[9rem] md:text-[12rem] leading-[0.75] text-terracotta select-none">I</span>
            <div class="pt-6">
              <h3 class="font-display text-4xl md:text-5xl">Свадьба</h3>
              <p class="mt-2 text-muted font-serif italic text-xl">во Владикавказе</p>
            </div>
          </div>
          <p class="mt-10 leading-relaxed text-ink/80">
            Торжественная часть, ужин, музыка и танцы до поздней ночи — день, в котором нам важен каждый из вас.
          </p>
          <dl class="mt-10 grid grid-cols-2 gap-6 text-sm">
            <div>
              <dt class="eyebrow">Начало</dt>
              <dd class="mt-2 font-serif italic text-lg">уточним ближе</dd>
            </div>
            <div>
              <dt class="eyebrow">Адрес</dt>
              <dd class="mt-2 font-serif italic text-lg">пришлём отдельно</dd>
            </div>
          </dl>
        </div>
      </article>

      {includePicnic && (
        <article class="relative overflow-hidden reveal vintage-border bg-gradient-to-br from-[#E3E7DA] via-paper to-[#D1DBC5] p-10 md:p-14">
          <div class="grain"></div>
          <div class="relative">
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-xs tracking-editorial uppercase text-moss">Актъ второй</span>
              <span class="font-mono text-xs tracking-editorial uppercase text-muted">20 · 09</span>
            </div>
            <div class="mt-6 flex items-start gap-6">
              <span class="font-display serif-italic text-[9rem] md:text-[12rem] leading-[0.75] text-moss select-none">II</span>
              <div class="pt-6">
                <h3 class="font-display text-4xl md:text-5xl">Пикник</h3>
                <p class="mt-2 text-muted font-serif italic text-xl">в горах Осетии</p>
              </div>
            </div>
            <p class="mt-10 leading-relaxed text-ink/80">
              Уезжаем небольшой компанией в горы — провести день неспешно, с едой на траве, тишиной и видом, который останется с вами надолго.
            </p>
            <dl class="mt-10 grid grid-cols-2 gap-6 text-sm">
              <div>
                <dt class="eyebrow">Сбор</dt>
                <dd class="mt-2 font-serif italic text-lg">утром, от отеля</dd>
              </div>
              <div>
                <dt class="eyebrow">Место</dt>
                <dd class="mt-2 font-serif italic text-lg">сюрприз</dd>
              </div>
            </dl>
          </div>
        </article>
      )}
    </div>
  </div>
</section>
