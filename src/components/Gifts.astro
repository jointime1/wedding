---
import Ornament from './Ornament.astro';
---
<section class="section relative">
  <div class="container-narrow text-center">
    <p class="eyebrow reveal"><span class="dot-ornament"></span>Про подарки<span class="dot-ornament"></span></p>

    <div class="mt-8 reveal text-clay/55">
      <Ornament variant="leaves" class="mx-auto" />
    </div>

    <blockquote class="mt-12 relative reveal mx-auto max-w-2xl">
      <span aria-hidden="true"
            class="absolute -top-12 left-1/2 -translate-x-1/2 font-display serif-italic text-[10rem] text-terracotta/25 leading-none select-none">“</span>
      <p class="relative font-display italic text-3xl md:text-4xl leading-[1.3]">
        Мы ничего не ждём в&nbsp;подарок — ваш приезд и&nbsp;есть лучший подарок. Просто будьте с&nbsp;нами.
      </p>
      <span aria-hidden="true"
            class="absolute -bottom-20 left-1/2 -translate-x-1/2 font-display serif-italic text-[10rem] text-terracotta/25 leading-none select-none rotate-180">“</span>
    </blockquote>

    <div class="mt-20 flex items-center justify-center gap-4 reveal text-ink/40">
      <span class="hair-rule w-12"></span>
      <p class="font-mono text-[0.7rem] tracking-editorial uppercase">— Дана &amp; Саша</p>
      <span class="hair-rule w-12"></span>
    </div>
  </div>
</section>
