---
export interface Props { class?: string; variant?: 'rule' | 'sun' | 'leaves' | 'diamond' }
const { class: cls = '', variant = 'rule' } = Astro.props;
---
{variant === 'rule' && (
  <svg viewBox="0 0 240 24" class={`w-48 h-6 ${cls}`} aria-hidden="true" fill="none">
    <path d="M0 12 H88" stroke="currentColor" stroke-width="0.75" opacity="0.5" />
    <path d="M152 12 H240" stroke="currentColor" stroke-width="0.75" opacity="0.5" />
    <path d="M120 4 L128 12 L120 20 L112 12 Z" stroke="currentColor" stroke-width="0.75" fill="none" />
    <circle cx="120" cy="12" r="1.4" fill="currentColor" />
    <circle cx="100" cy="12" r="0.9" fill="currentColor" opacity="0.6" />
    <circle cx="140" cy="12" r="0.9" fill="currentColor" opacity="0.6" />
    <path d="M88 12 q 6 -6 12 0 t 12 0" stroke="currentColor" stroke-width="0.75" fill="none" opacity="0.6" />
    <path d="M140 12 q 6 -6 12 0 t 12 0" stroke="currentColor" stroke-width="0.75" fill="none" opacity="0.6" />
  </svg>
)}

{variant === 'leaves' && (
  <svg viewBox="0 0 320 40" class={`w-72 h-10 ${cls}`} aria-hidden="true" fill="none">
    <path d="M0 20 H120" stroke="currentColor" stroke-width="0.75" opacity="0.45" />
    <path d="M200 20 H320" stroke="currentColor" stroke-width="0.75" opacity="0.45" />
    <g stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round">
      <path d="M160 6 C 152 14, 152 26, 160 34 C 168 26, 168 14, 160 6 Z" />
      <path d="M160 6 V 34" opacity="0.5" />
      <path d="M140 18 C 132 14, 124 12, 116 16 C 124 18, 134 18, 140 18 Z" transform="rotate(-10 140 18)" />
      <path d="M180 18 C 188 14, 196 12, 204 16 C 196 18, 186 18, 180 18 Z" transform="rotate(10 180 18)" />
      <path d="M140 26 C 132 30, 124 32, 116 28 C 124 26, 134 26, 140 26 Z" transform="rotate(10 140 26)" />
      <path d="M180 26 C 188 30, 196 32, 204 28 C 196 26, 186 26, 180 26 Z" transform="rotate(-10 180 26)" />
      <circle cx="160" cy="20" r="1.6" fill="currentColor" />
    </g>
  </svg>
)}

{variant === 'sun' && (
  <svg viewBox="0 0 120 120" class={`w-32 h-32 ${cls}`} aria-hidden="true" fill="none">
    <g stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round">
      <circle cx="60" cy="60" r="22" />
      <circle cx="60" cy="60" r="14" opacity="0.5" />
      <circle cx="60" cy="60" r="3" fill="currentColor" />
      <!-- 7 curved rays — Alanian sun motif -->
      <g>
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(51.4 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(102.8 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(154.2 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(205.6 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(257 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <g transform="rotate(308.4 60 60)">
        <path d="M60 38 C 64 30, 66 26, 60 16 C 54 26, 56 30, 60 38 Z" />
      </g>
      <!-- inner cross -->
      <path d="M60 49 V 71 M 49 60 H 71" opacity="0.5" />
    </g>
  </svg>
)}

{variant === 'diamond' && (
  <svg viewBox="0 0 28 28" class={`w-7 h-7 ${cls}`} aria-hidden="true" fill="none">
    <path d="M14 2 L 26 14 L 14 26 L 2 14 Z" stroke="currentColor" stroke-width="0.9" />
    <path d="M14 9 L 19 14 L 14 19 L 9 14 Z" stroke="currentColor" stroke-width="0.7" opacity="0.6" />
    <circle cx="14" cy="14" r="1.2" fill="currentColor" />
  </svg>
)}
