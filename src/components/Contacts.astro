---
import Ornament from './Ornament.astro';
const env = import.meta.env;
const dana = env.PUBLIC_CONTACT_DANA ?? '';
const alex = env.PUBLIC_CONTACT_ALEX ?? '';
---
<section class="section">
  <div class="container-wide">
    <div class="text-center reveal">
      <p class="eyebrow">По всем вопросам</p>
      <h2 class="mt-5 text-4xl md:text-5xl font-display">Пишите нам <span class="serif-italic text-terracotta">напрямую</span></h2>
      <div class="mt-6 text-ink/60"><Ornament /></div>
    </div>

    <div class="mt-16 grid gap-px sm:grid-cols-2 bg-ink/15 border border-ink/15 reveal">
      <div class="bg-paper p-10 md:p-14 text-center">
        <p class="eyebrow">Невеста</p>
        <p class="mt-5 font-display serif-italic text-5xl">Дана</p>
        <p class="mt-4 font-mono text-sm tracking-wider">{dana || '+7 000 000 00 00'}</p>
      </div>
      <div class="bg-paper p-10 md:p-14 text-center">
        <p class="eyebrow">Жених</p>
        <p class="mt-5 font-display serif-italic text-5xl">Александр</p>
        <p class="mt-4 font-mono text-sm tracking-wider">{alex || '+7 000 000 00 00'}</p>
      </div>
    </div>
  </div>
</section>

<footer class="relative pb-20 pt-8 text-center overflow-hidden">
  <div class="container-narrow">
    <p class="font-display serif-italic text-3xl reveal">
      <span>Дана</span>
      <span class="text-terracotta mx-3">&amp;</span>
      <span>Александр</span>
    </p>
    <p class="mt-3 font-mono text-[0.65rem] tracking-editorial uppercase text-muted reveal">
      Владикавказ · MMXXVI
    </p>
  </div>
</footer>
