---
export interface Props {
  includePicnic: boolean;
}
const { includePicnic } = Astro.props;

const env = import.meta.env;
const action = env.PUBLIC_GOOGLE_FORM_ACTION ?? '';
const eName = env.PUBLIC_ENTRY_NAME ?? 'entry.name';
const eAttending = env.PUBLIC_ENTRY_ATTENDING ?? 'entry.attending';
const ePlusOne = env.PUBLIC_ENTRY_PLUS_ONE ?? 'entry.plusOne';
const ePicnic = env.PUBLIC_ENTRY_PICNIC ?? 'entry.picnic';
const eNote = env.PUBLIC_ENTRY_NOTE ?? 'entry.note';
---
<section id="rsvp" class="section border-t border-ink/5 bg-cream">
  <div class="container-narrow">
    <h2 class="text-3xl md:text-4xl text-center reveal">Подтвердите, пожалуйста</h2>
    <div class="rule mt-6 reveal"></div>
    <p class="mt-6 text-center text-muted reveal">
      Отметьте, будете ли с нами 19
      {includePicnic ? '–20' : ''} сентября, чтобы нам было проще всё спланировать.
    </p>

    <form
      id="rsvp-form"
      action={action}
      method="POST"
      target="rsvp-sink"
      class="mt-12 grid gap-6 reveal"
    >
      <label class="block">
        <span class="text-sm tracking-wide text-muted">Ваше имя</span>
        <input
          name={eName}
          type="text"
          required
          autocomplete="name"
          class="mt-2 w-full border-0 border-b border-ink/20 bg-transparent py-2 text-lg focus:border-terracotta focus:outline-none focus:ring-0"
        />
      </label>

      <fieldset class="mt-4">
        <legend class="text-sm tracking-wide text-muted">Будете 19{includePicnic ? '–20' : ''} сентября?</legend>
        <div class="mt-3 flex flex-wrap gap-6">
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="radio" name={eAttending} value="Да, буду" required class="accent-terracotta" />
            <span>Да, буду</span>
          </label>
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="radio" name={eAttending} value="К сожалению, не смогу" class="accent-terracotta" />
            <span>К сожалению, не смогу</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="mt-2">
        <legend class="text-sm tracking-wide text-muted">Придёте один или с парой?</legend>
        <div class="mt-3 flex flex-wrap gap-6">
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="radio" name={ePlusOne} value="Один(одна)" class="accent-terracotta" />
            <span>Один(одна)</span>
          </label>
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="radio" name={ePlusOne} value="С +1" class="accent-terracotta" />
            <span>С +1</span>
          </label>
        </div>
      </fieldset>

      {includePicnic && (
        <fieldset class="mt-2">
          <legend class="text-sm tracking-wide text-muted">Поедете с нами на пикник 20 сентября?</legend>
          <div class="mt-3 flex flex-wrap gap-6">
            <label class="inline-flex items-center gap-2 cursor-pointer">
              <input type="radio" name={ePicnic} value="Да, поеду" class="accent-terracotta" />
              <span>Да, поеду</span>
            </label>
            <label class="inline-flex items-center gap-2 cursor-pointer">
              <input type="radio" name={ePicnic} value="Только свадьба" class="accent-terracotta" />
              <span>Только свадьба</span>
            </label>
          </div>
        </fieldset>
      )}

      <label class="block">
        <span class="text-sm tracking-wide text-muted">Комментарий (по желанию)</span>
        <textarea
          name={eNote}
          rows="3"
          class="mt-2 w-full border border-ink/15 bg-transparent px-3 py-2 focus:border-terracotta focus:outline-none focus:ring-0"
        ></textarea>
      </label>

      <button
        type="submit"
        class="mt-4 inline-flex justify-center self-center bg-ink px-10 py-4 text-sm tracking-[0.25em] uppercase text-cream transition hover:bg-terracotta cursor-pointer"
      >
        Отправить
      </button>
    </form>

    <div id="rsvp-thanks" class="hidden mt-12 text-center reveal">
      <p class="font-display text-3xl">Спасибо!</p>
      <p class="mt-3 text-muted">Мы получили ваш ответ. До встречи в сентябре.</p>
    </div>

    <iframe name="rsvp-sink" class="hidden" aria-hidden="true" title="rsvp"></iframe>
  </div>
</section>

<script>
  const form = document.getElementById('rsvp-form');
  const thanks = document.getElementById('rsvp-thanks');
  form?.addEventListener('submit', () => {
    setTimeout(() => {
      form.classList.add('hidden');
      thanks?.classList.remove('hidden');
      thanks?.classList.add('is-visible');
      thanks?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 400);
  });
</script>
