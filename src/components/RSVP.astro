---
import Ornament from './Ornament.astro';
export interface Props { includePicnic: boolean }
const { includePicnic } = Astro.props;

const env = import.meta.env;
const action = env.PUBLIC_GOOGLE_FORM_ACTION ?? '';
const eName = env.PUBLIC_ENTRY_NAME ?? 'entry.name';
const eAttending = env.PUBLIC_ENTRY_ATTENDING ?? 'entry.attending';
const ePlusOne = env.PUBLIC_ENTRY_PLUS_ONE ?? 'entry.plusOne';
const ePicnic = env.PUBLIC_ENTRY_PICNIC ?? 'entry.picnic';
const eNote = env.PUBLIC_ENTRY_NOTE ?? 'entry.note';
---
<section id="rsvp" class="section relative bg-[#EEE3CB] overflow-hidden">
  <!-- subtle pattern -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.06]"
       style="background-image: radial-gradient(#1A1410 1px, transparent 1.5px); background-size: 22px 22px;"></div>
  <div class="grain"></div>

  <div class="container-narrow relative">
    <div class="text-center reveal">
      <p class="eyebrow">Respondez s'il vous plaît</p>
      <div class="mt-4 mx-auto text-clay/60"><Ornament variant="diamond" class="mx-auto w-5 h-5" /></div>
      <h2 class="mt-5 text-5xl md:text-7xl font-display">
        Будете <span class="serif-italic text-terracotta underline-hand">с&nbsp;нами?</span>
      </h2>
      <p class="mt-6 text-muted max-w-md mx-auto">
        Отметьте, придёте ли вы 19{includePicnic ? '–20' : ''} сентября, чтобы нам было проще всё спланировать.
      </p>
    </div>

    <div class="relative mt-16 reveal">
      <!-- Perforated postage stamp in top-right -->
      <div class="absolute -top-8 -right-2 md:-right-8 w-24 h-28 perforate bg-paper rotate-6 z-10 shadow-[0_8px_18px_-10px_rgba(0,0,0,0.4)]">
        <div class="absolute inset-2 border border-clay/40 flex flex-col items-center justify-center text-clay">
          <span class="font-display serif-italic text-2xl leading-none">Д</span>
          <span class="font-display text-[0.55rem] tracking-[0.4em] my-0.5 opacity-70">&amp;</span>
          <span class="font-display serif-italic text-2xl leading-none">А</span>
          <span class="font-mono text-[0.5rem] tracking-widest mt-1.5">MMXXVI</span>
        </div>
      </div>

      <!-- Cancellation rings (postal mark) -->
      <div class="absolute top-2 right-20 w-20 h-20 border-2 border-clay/30 rounded-full pointer-events-none rotate-12 hidden md:flex items-center justify-center">
        <div class="text-center font-mono text-[0.5rem] tracking-[0.25em] uppercase text-clay/60 leading-tight">
          Vladi<br/>kavkaz<br/>· 2026 ·
        </div>
      </div>

      <!-- corner marks -->
      <span class="absolute -top-1 -left-1 w-5 h-5 border-t border-l border-ink/40"></span>
      <span class="absolute -bottom-1 -left-1 w-5 h-5 border-b border-l border-ink/40"></span>
      <span class="absolute -bottom-1 -right-1 w-5 h-5 border-b border-r border-ink/40"></span>

      <form
        id="rsvp-form"
        action={action}
        method="POST"
        target="rsvp-sink"
        class="bg-paper p-8 md:p-14 vintage-border grid gap-8 relative"
      >
        <!-- Postcard header strip -->
        <div class="flex items-center justify-between border-b border-ink/15 pb-5">
          <span class="font-mono text-[0.6rem] tracking-[0.3em] uppercase text-muted">Reply Card</span>
          <Ornament variant="diamond" class="w-3 h-3 text-clay" />
          <span class="font-mono text-[0.6rem] tracking-[0.3em] uppercase text-muted">№ {includePicnic ? '01-02' : '01'}</span>
        </div>

        <label class="block">
          <span class="eyebrow">Ваше имя</span>
          <input
            name={eName}
            type="text"
            required
            autocomplete="name"
            class="mt-2 w-full border-0 border-b border-ink/30 bg-transparent py-3 text-xl font-serif italic focus:border-terracotta focus:outline-none focus:ring-0 placeholder:text-ink/30"
            placeholder="Иван Иванов"
          />
        </label>

        <fieldset>
          <legend class="eyebrow">Будете 19{includePicnic ? '–20' : ''} сентября?</legend>
          <div class="mt-4 grid sm:grid-cols-2 gap-3">
            <label class="group cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-terracotta transition-colors has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/5">
              <input type="radio" name={eAttending} value="Да, буду" required class="accent-terracotta" />
              <span class="font-serif italic text-lg">Да, буду</span>
            </label>
            <label class="group cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-terracotta transition-colors has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/5">
              <input type="radio" name={eAttending} value="К сожалению, не смогу" class="accent-terracotta" />
              <span class="font-serif italic text-lg">Не смогу</span>
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend class="eyebrow">Придёте один(одна) или с&nbsp;+1?</legend>
          <div class="mt-4 grid sm:grid-cols-2 gap-3">
            <label class="cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-terracotta transition-colors has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/5">
              <input type="radio" name={ePlusOne} value="Один(одна)" class="accent-terracotta" />
              <span class="font-serif italic text-lg">Один(одна)</span>
            </label>
            <label class="cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-terracotta transition-colors has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/5">
              <input type="radio" name={ePlusOne} value="С +1" class="accent-terracotta" />
              <span class="font-serif italic text-lg">С&nbsp;+1</span>
            </label>
          </div>
        </fieldset>

        {includePicnic && (
          <fieldset>
            <legend class="eyebrow">Поедете на пикник 20 сентября?</legend>
            <div class="mt-4 grid sm:grid-cols-2 gap-3">
              <label class="cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-moss transition-colors has-[:checked]:border-moss has-[:checked]:bg-moss/5">
                <input type="radio" name={ePicnic} value="Да, поеду" class="accent-moss" />
                <span class="font-serif italic text-lg">Да, в горы</span>
              </label>
              <label class="cursor-pointer flex items-center gap-3 border border-ink/20 px-5 py-4 hover:border-moss transition-colors has-[:checked]:border-moss has-[:checked]:bg-moss/5">
                <input type="radio" name={ePicnic} value="Только свадьба" class="accent-moss" />
                <span class="font-serif italic text-lg">Только свадьба</span>
              </label>
            </div>
          </fieldset>
        )}

        <label class="block">
          <span class="eyebrow">Комментарий (по желанию)</span>
          <textarea
            name={eNote}
            rows="3"
            class="mt-2 w-full border border-ink/20 bg-transparent px-4 py-3 font-serif italic text-lg focus:border-terracotta focus:outline-none focus:ring-0"
            placeholder="Например: приеду с ребёнком, есть аллергия…"
          ></textarea>
        </label>

        <div class="flex flex-col items-center gap-3 pt-2">
          <button
            type="submit"
            class="group relative inline-flex items-center gap-3 overflow-hidden bg-ink px-12 py-5 font-mono text-xs tracking-editorial uppercase text-paper transition-all hover:bg-terracotta cursor-pointer"
          >
            <span class="relative z-10">Отправить ответ</span>
            <svg width="22" height="10" viewBox="0 0 22 10" fill="none" class="relative z-10 transition-transform group-hover:translate-x-1" aria-hidden="true">
              <path d="M0 5 H20 M15 1 L20 5 L15 9" stroke="currentColor" stroke-width="1" />
            </svg>
          </button>
          <p class="font-mono text-[0.6rem] tracking-editorial uppercase text-muted">
            Ждём до 1 августа 2026
          </p>
        </div>
      </form>
    </div>

    <div id="rsvp-thanks" class="hidden mt-16 text-center reveal">
      <div class="mx-auto text-terracotta/60"><Ornament variant="leaves" class="mx-auto" /></div>
      <p class="mt-6 font-display serif-italic text-6xl text-terracotta">Спасибо!</p>
      <p class="mt-4 text-muted font-serif italic text-xl">Мы получили ваш ответ. До встречи в сентябре.</p>
    </div>

    <iframe name="rsvp-sink" class="hidden" aria-hidden="true" title="rsvp"></iframe>
  </div>
</section>

<script>
  const form = document.getElementById('rsvp-form');
  const thanks = document.getElementById('rsvp-thanks');
  form?.addEventListener('submit', () => {
    setTimeout(() => {
      form.classList.add('hidden');
      thanks?.classList.remove('hidden');
      thanks?.classList.add('is-visible');
      thanks?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 400);
  });
</script>
