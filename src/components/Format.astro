---
import Ornament from './Ornament.astro';
export interface Props { includePicnic: boolean }
const { includePicnic } = Astro.props;
---
<section class="section relative">
  <!-- decorative side ornaments -->
  <div class="hidden md:block absolute top-32 left-10 text-clay/30 reveal">
    <Ornament variant="diamond" class="w-6 h-6" />
  </div>
  <div class="hidden md:block absolute bottom-32 right-12 text-moss/40 reveal">
    <Ornament variant="diamond" class="w-6 h-6" />
  </div>

  <div class="container-narrow relative">
    <div class="text-center">
      <p class="eyebrow reveal">
        <span class="dot-ornament"></span>О формате<span class="dot-ornament"></span>
      </p>

      <div class="mt-6 reveal text-terracotta/70">
        <Ornament variant="leaves" class="mx-auto" />
      </div>

      <p class="mt-10 font-display italic text-3xl md:text-5xl leading-[1.18] reveal">
        {includePicnic
          ? 'Мы зовём вас на два дня — большой вечер во Владикавказе и тихое утро в горах.'
          : 'Мы зовём вас на наш день — большой, тёплый и важный для нас вечер во Владикавказе.'}
      </p>

      <div class="mt-12 text-ink/55 reveal"><Ornament variant="rule" /></div>
    </div>

    <!-- Letter-style paragraph with drop cap -->
    <div class="mt-12 reveal mx-auto max-w-xl text-left">
      <p class="dropcap text-ink/85 leading-[1.85] text-[1.05rem]">
        {includePicnic
          ? 'Девятнадцатого сентября — торжество, музыка и все, кто нам дорог. Двадцатого — уезжаем небольшой компанией в горы на пикник, чтобы побыть вместе ещё немного, без расписания и спешки.'
          : 'Всё главное — в один вечер. Встречаемся в сентябре во Владикавказе и отмечаем как следует: с долгими тостами, музыкой и людьми, без которых эта свадьба была бы не та.'}
      </p>
      <p class="mt-6 text-right font-display serif-italic text-2xl text-clay">
        — с любовью, Дана и Саша
      </p>
    </div>
  </div>
</section>
