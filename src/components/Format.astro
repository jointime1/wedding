---
import Ornament from './Ornament.astro';
export interface Props { includePicnic: boolean }
const { includePicnic } = Astro.props;
---
<section id="format" class="section relative">
  <!-- decorative side ornaments -->
  <div class="hidden md:block absolute top-32 left-10 text-clay/30 reveal float-soft">
    <Ornament variant="diamond" class="w-6 h-6" />
  </div>
  <div class="hidden md:block absolute bottom-32 right-12 text-moss/40 reveal float-soft">
    <Ornament variant="diamond" class="w-6 h-6" />
  </div>

  <div class="container-narrow relative">
    <div class="text-center">
      <p class="eyebrow reveal">
        <span class="dot-ornament"></span>О формате<span class="dot-ornament"></span>
      </p>

      <div class="mt-6 reveal text-terracotta/70">
        <Ornament variant="leaves" class="mx-auto" />
      </div>

      <p class="mt-10 font-display italic text-3xl md:text-5xl leading-[1.18] reveal">
        {includePicnic
          ? 'Мы зовём вас на два дня — большой вечер во Владикавказе и тихое утро в горах.'
          : 'Мы зовём вас на наш день — большой, тёплый и важный для нас вечер во Владикавказе.'}
      </p>

      <div class="mt-12 text-ink/55 reveal"><Ornament variant="rule" /></div>
    </div>

    <!-- Letter-style paragraph with drop cap -->
    <div class="mt-12 reveal mx-auto max-w-xl text-left">
      <p class="dropcap text-ink/85 leading-[1.85] text-[1.05rem]">
        {includePicnic
          ? 'Девятнадцатого сентября — торжество, музыка и все, кто нам дорог. Двадцатого — уезжаем небольшой компанией в горы на пикник, чтобы побыть вместе ещё немного, без расписания и спешки.'
          : 'Всё главное — в один вечер. Встречаемся в сентябре во Владикавказе и отмечаем как следует: с долгими тостами, музыкой и людьми, без которых эта свадьба была бы не та.'}
      </p>

      <!-- Animated handwritten signature -->
      <div class="mt-8 text-right reveal">
        <svg viewBox="0 0 360 80" class="inline-block w-64 md:w-80 h-auto text-clay" aria-label="С любовью, Дана и Саша">
          <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <!-- "с любовью," script -->
            <path class="signature-path"
                  style="--len: 380;"
                  d="M10 38 c -4 6, 0 14, 8 14 s 14 -6, 14 -14 s -8 -10, -10 -2 c -2 8, 6 14, 16 12 q 8 -2, 12 -10 q 4 -10, -2 -10 q -6 0, -8 8 q -2 8, 6 12 q 12 4, 22 -6 q 6 -8, 8 -16 q 0 -8, -6 -6 q -6 4, -6 14 q 0 12, 12 16 q 12 2, 22 -8 q 8 -8, 12 -16 q 4 -10, -2 -8 q -6 4, -6 14 q 2 12, 14 14 q 12 0, 22 -10 q 8 -10, 8 -18 q -2 -6, -8 -2 q -6 6, -2 16 q 4 12, 16 14 q 12 0, 18 -8" />
            <!-- " — Дана & Саша" italic -->
            <path class="signature-path"
                  style="--len: 320;"
                  d="M210 56 q 6 0, 14 -4 q 8 -4, 16 -4 q 8 0, 12 6 q 4 8, -2 14 q -10 6, -14 -2 q -2 -10, 8 -16 q 12 -6, 22 0 q 8 6, 0 14 q -8 6, -16 0 q -6 -8, 2 -14 q 12 -8, 24 -2 q 10 6, 6 14 q -6 8, -16 4 q -8 -6, 0 -14 q 10 -8, 22 -2" />
            <!-- ampersand flourish -->
            <path class="signature-path"
                  style="--len: 80;"
                  d="M180 44 q -8 -4, -10 4 q 0 8, 8 10 q 10 0, 14 -8" />
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>
