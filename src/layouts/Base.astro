---
import '../styles/global.css';
import EnvelopeIntro from '../components/EnvelopeIntro.astro';
import Atmosphere from '../components/Atmosphere.astro';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Дана & Александр · 19–20 сентября 2026',
  description = 'Наша свадьба во Владикавказе, 19–20 сентября 2026.',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative">
    <EnvelopeIntro />
    <Atmosphere />

    <!-- Floating petals layer (decorative, cursor-reactive) -->
    <div class="petals-layer" id="petals-layer" aria-hidden="true"></div>

    <!-- Confetti canvas (easter egg) -->
    <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>

    <!-- Page-section marginalia indicator -->
    <nav class="page-marker" aria-label="Разделы">
      <ol class="page-marker-track">
        <li><a href="#hero" class="page-marker-item" data-target="hero"><span class="pm-label">Приглашение</span><span class="pm-tick"></span><span>I</span></a></li>
        <li><a href="#format" class="page-marker-item" data-target="format"><span class="pm-label">Формат</span><span class="pm-tick"></span><span>II</span></a></li>
        <li><a href="#schedule" class="page-marker-item" data-target="schedule"><span class="pm-label">Программа</span><span class="pm-tick"></span><span>III</span></a></li>
        <li><a href="#guestbook" class="page-marker-item" data-target="guestbook"><span class="pm-label">Книга</span><span class="pm-tick"></span><span>IV</span></a></li>
        <li><a href="#rsvp" class="page-marker-item" data-target="rsvp"><span class="pm-label">RSVP</span><span class="pm-tick"></span><span>V</span></a></li>
        <li><a href="#contacts" class="page-marker-item" data-target="contacts"><span class="pm-label">Контакты</span><span class="pm-tick"></span><span>VI</span></a></li>
      </ol>
    </nav>

    <slot />

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const hoverDevice = window.matchMedia('(hover: hover)').matches && window.innerWidth >= 768;

      // ─── Reveal on scroll ──────────────────────────────────────────────
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // ─── Mouse position tracking (shared) ──────────────────────────────
      const pointer = { x: window.innerWidth / 2, y: window.innerHeight / 2, active: false };
      const onPointerMove = (e: MouseEvent) => {
        pointer.x = e.clientX;
        pointer.y = e.clientY;
        pointer.active = true;
      };
      window.addEventListener('mousemove', onPointerMove, { passive: true });

      // ─── Mouse parallax ────────────────────────────────────────────────
      if (!reduceMotion) {
        const parallaxRoots = document.querySelectorAll<HTMLElement>('[data-parallax-root]');
        let mxTarget = 0, myTarget = 0, mxCur = 0, myCur = 0, raf = 0;

        const onMove = (e: MouseEvent) => {
          const w = window.innerWidth, h = window.innerHeight;
          mxTarget = (e.clientX / w - 0.5) * 2;
          myTarget = (e.clientY / h - 0.5) * 2;
          if (!raf) raf = requestAnimationFrame(tick);
        };
        const tick = () => {
          mxCur += (mxTarget - mxCur) * 0.08;
          myCur += (myTarget - myCur) * 0.08;
          parallaxRoots.forEach((root) => {
            root.style.setProperty('--mx', mxCur.toFixed(3));
            root.style.setProperty('--my', myCur.toFixed(3));
          });
          if (Math.abs(mxTarget - mxCur) > 0.001 || Math.abs(myTarget - myCur) > 0.001) {
            raf = requestAnimationFrame(tick);
          } else { raf = 0; }
        };
        window.addEventListener('mousemove', onMove, { passive: true });
      }

      // ─── Scroll parallax for mountain layers ──────────────────────────
      if (!reduceMotion) {
        const scrollRoots = document.querySelectorAll<HTMLElement>('[data-scroll-parallax]');
        const onScroll = () => {
          for (const root of scrollRoots) {
            const rect = root.getBoundingClientRect();
            const wh = window.innerHeight;
            const progress = Math.max(0, Math.min(1, (wh - rect.top) / (wh + rect.height)));
            root.style.setProperty('--sy', progress.toFixed(3));
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // ─── 3D tilt cards ────────────────────────────────────────────────
      if (!reduceMotion && hoverDevice) {
        document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
          let rect: DOMRect | null = null;
          const onEnter = () => { rect = card.getBoundingClientRect(); card.classList.add('is-tilting'); };
          const onMove = (e: MouseEvent) => {
            if (!rect) rect = card.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width - 0.5;
            const y = (e.clientY - rect.top) / rect.height - 0.5;
            card.style.setProperty('--tx', x.toFixed(3));
            card.style.setProperty('--ty', y.toFixed(3));
          };
          const onLeave = () => {
            card.classList.remove('is-tilting');
            card.style.setProperty('--tx', '0');
            card.style.setProperty('--ty', '0');
            rect = null;
          };
          card.addEventListener('mouseenter', onEnter);
          card.addEventListener('mousemove', onMove);
          card.addEventListener('mouseleave', onLeave);
        });
      }

      // ─── Magnetic button ──────────────────────────────────────────────
      if (!reduceMotion && hoverDevice) {
        document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((btn) => {
          const strength = Number(btn.dataset.magnetic) || 14;
          const onMove = (e: MouseEvent) => {
            const rect = btn.getBoundingClientRect();
            const x = (e.clientX - (rect.left + rect.width / 2)) / rect.width;
            const y = (e.clientY - (rect.top + rect.height / 2)) / rect.height;
            btn.style.setProperty('--mag-x', `${x * strength}px`);
            btn.style.setProperty('--mag-y', `${y * strength}px`);
          };
          const onLeave = () => {
            btn.style.setProperty('--mag-x', '0px');
            btn.style.setProperty('--mag-y', '0px');
          };
          btn.addEventListener('mousemove', onMove);
          btn.addEventListener('mouseleave', onLeave);
        });
      }

      // ─── Page marker (active section) ─────────────────────────────────
      const marker = document.querySelector<HTMLElement>('.page-marker');
      if (marker) {
        const items = marker.querySelectorAll<HTMLElement>('.page-marker-item');
        const sections: { id: string; el: HTMLElement; item: HTMLElement }[] = [];
        items.forEach((item) => {
          const id = item.dataset.target!;
          const el = document.getElementById(id);
          if (el) sections.push({ id, el, item });
        });
        const onScroll = () => {
          const y = window.scrollY + window.innerHeight * 0.35;
          let active = sections[0];
          for (const s of sections) {
            if (s.el.offsetTop <= y) active = s;
          }
          for (const s of sections) {
            s.item.classList.toggle('is-active', s === active);
          }
          marker.classList.toggle('is-shown', window.scrollY > window.innerHeight * 0.6);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // ─── Petals layer (cursor-reactive) ───────────────────────────────
      type PetalState = { el: HTMLElement; vx: number; vy: number; offX: number; offY: number };
      const petalStates: PetalState[] = [];
      if (!reduceMotion) {
        const layer = document.getElementById('petals-layer');
        if (layer) {
          const variants = ['', 'leaf', 'gold'];
          const count = window.innerWidth < 768 ? 8 : 18;
          for (let i = 0; i < count; i++) {
            const p = document.createElement('span');
            p.className = `petal ${variants[i % variants.length]}`;
            const left = Math.random() * 100;
            const dur = 18 + Math.random() * 18;
            const delay = -Math.random() * 30;
            const drift = (Math.random() - 0.5) * 220;
            p.style.left = `${left}vw`;
            p.style.setProperty('--dur', `${dur}s`);
            p.style.setProperty('--delay', `${delay}s`);
            p.style.setProperty('--drift', `${drift}px`);
            layer.appendChild(p);
            petalStates.push({ el: p, vx: 0, vy: 0, offX: 0, offY: 0 });
          }

          // Cursor-reactive petals — push away when cursor near
          if (hoverDevice) {
            const tickPetals = () => {
              petalStates.forEach((s) => {
                const r = s.el.getBoundingClientRect();
                const cx = r.left + r.width / 2;
                const cy = r.top + r.height / 2;
                const dx = cx - pointer.x;
                const dy = cy - pointer.y;
                const dist2 = dx * dx + dy * dy;
                const RADIUS = 110;
                if (dist2 < RADIUS * RADIUS && pointer.active) {
                  const dist = Math.sqrt(dist2) || 1;
                  const force = (1 - dist / RADIUS) * 6;
                  s.vx += (dx / dist) * force;
                  s.vy += (dy / dist) * force * 0.6;
                }
                s.vx *= 0.86; s.vy *= 0.86;
                s.offX += s.vx; s.offY += s.vy;
                s.offX *= 0.92; s.offY *= 0.92;
                s.el.style.setProperty('--ox', `${s.offX.toFixed(1)}px`);
                s.el.style.setProperty('--oy', `${s.offY.toFixed(1)}px`);
              });
              requestAnimationFrame(tickPetals);
            };
            requestAnimationFrame(tickPetals);
          }
        }
      }

      // ─── Wax seal click — drop ink imprint onto the page ─────────────
      document.querySelectorAll<HTMLElement>('[data-wax-seal]').forEach((seal) => {
        const host = seal.closest<HTMLElement>('section') || document.body;
        if (getComputedStyle(host).position === 'static') host.style.position = 'relative';
        seal.addEventListener('click', () => {
          const imprint = document.createElement('span');
          imprint.className = 'wax-imprint';
          const hostRect = host.getBoundingClientRect();
          const sealRect = seal.getBoundingClientRect();
          const cx = sealRect.left - hostRect.left + sealRect.width / 2 - 45;
          const cy = sealRect.top - hostRect.top + sealRect.height / 2 - 45;
          imprint.style.left = `${cx + (Math.random() - 0.5) * 60}px`;
          imprint.style.top = `${cy + (Math.random() - 0.5) * 60}px`;
          imprint.style.transform = `rotate(${(Math.random() - 0.5) * 30}deg)`;
          host.appendChild(imprint);
          setTimeout(() => imprint.remove(), 1500);
        });
      });

      // ─── Live countdown to 19 Sep 2026, 17:00 (Vladikavkaz, UTC+3) ────
      const cd = document.querySelector<HTMLElement>('[data-countdown]');
      if (cd) {
        const target = new Date('2026-09-19T17:00:00+03:00').getTime();
        const tiles = {
          d: cd.querySelector<HTMLElement>('[data-cd="d"]'),
          h: cd.querySelector<HTMLElement>('[data-cd="h"]'),
          m: cd.querySelector<HTMLElement>('[data-cd="m"]'),
          s: cd.querySelector<HTMLElement>('[data-cd="s"]'),
        };
        const last: Record<string, string> = { d: '', h: '', m: '', s: '' };
        const setTile = (key: 'd' | 'h' | 'm' | 's', val: string) => {
          const el = tiles[key];
          if (!el) return;
          if (last[key] === val) return;
          last[key] = val;
          if (reduceMotion) { el.textContent = val; return; }
          el.classList.add('is-ticking');
          setTimeout(() => {
            el.textContent = val;
            el.classList.remove('is-ticking');
          }, 280);
        };
        const update = () => {
          const now = Date.now();
          const diff = Math.max(0, target - now);
          const days = Math.floor(diff / 86_400_000);
          const hours = Math.floor((diff % 86_400_000) / 3_600_000);
          const mins = Math.floor((diff % 3_600_000) / 60_000);
          const secs = Math.floor((diff % 60_000) / 1000);
          setTile('d', String(days).padStart(3, '0'));
          setTile('h', String(hours).padStart(2, '0'));
          setTile('m', String(mins).padStart(2, '0'));
          setTile('s', String(secs).padStart(2, '0'));
        };
        update();
        setInterval(update, 1000);
      }

      // ─── Easter egg: click "&" between names 7 times → confetti ───────
      const confettiCanvas = document.getElementById('confetti-canvas') as HTMLCanvasElement | null;
      const fireConfetti = () => {
        if (!confettiCanvas) return;
        const ctx = confettiCanvas.getContext('2d')!;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        confettiCanvas.width = window.innerWidth * dpr;
        confettiCanvas.height = window.innerHeight * dpr;
        confettiCanvas.style.width = window.innerWidth + 'px';
        confettiCanvas.style.height = window.innerHeight + 'px';
        ctx.scale(dpr, dpr);
        confettiCanvas.classList.add('is-active');
        const colors = ['#B85C3C', '#A8873E', '#6F7B66', '#D9A897', '#1A1410', '#F8F1E3'];
        type C = { x: number; y: number; vx: number; vy: number; a: number; rot: number; vr: number; size: number; color: string; shape: 'rect' | 'circle' };
        const pieces: C[] = [];
        const w = window.innerWidth, h = window.innerHeight;
        for (let i = 0; i < 220; i++) {
          pieces.push({
            x: w / 2 + (Math.random() - 0.5) * 80,
            y: h / 2,
            vx: (Math.random() - 0.5) * 14,
            vy: -(Math.random() * 14 + 6),
            a: 1,
            rot: Math.random() * Math.PI * 2,
            vr: (Math.random() - 0.5) * 0.3,
            size: 4 + Math.random() * 6,
            color: colors[Math.floor(Math.random() * colors.length)],
            shape: Math.random() < 0.5 ? 'rect' : 'circle',
          });
        }
        const tick = () => {
          ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
          let alive = false;
          for (const p of pieces) {
            p.vy += 0.3;
            p.x += p.vx; p.y += p.vy;
            p.rot += p.vr;
            p.a *= 0.99;
            if (p.y < h + 40 && p.a > 0.02) {
              alive = true;
              ctx.save();
              ctx.translate(p.x, p.y);
              ctx.rotate(p.rot);
              ctx.globalAlpha = p.a;
              ctx.fillStyle = p.color;
              if (p.shape === 'rect') {
                ctx.fillRect(-p.size / 2, -p.size / 4, p.size, p.size / 2);
              } else {
                ctx.beginPath();
                ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
                ctx.fill();
              }
              ctx.restore();
            }
          }
          if (alive) requestAnimationFrame(tick);
          else {
            ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
            confettiCanvas.classList.remove('is-active');
          }
        };
        requestAnimationFrame(tick);
      };

      let ampClicks = 0;
      let ampTimer = 0;
      document.querySelectorAll<HTMLElement>('[data-easter-amp]').forEach((amp) => {
        amp.style.cursor = 'pointer';
        amp.addEventListener('click', () => {
          ampClicks++;
          amp.style.transform = `scale(${1 + ampClicks * 0.04}) rotate(${ampClicks * 6 - 18}deg)`;
          amp.style.transition = 'transform 250ms cubic-bezier(.2,.6,.2,1)';
          clearTimeout(ampTimer);
          ampTimer = window.setTimeout(() => {
            ampClicks = 0;
            amp.style.transform = '';
          }, 1800);
          if (ampClicks >= 7) {
            ampClicks = 0;
            amp.style.transform = '';
            fireConfetti();
          }
        });
      });

      // ─── RSVP letter flight on submit ─────────────────────────────────
      const rsvpForm = document.getElementById('rsvp-form');
      const rsvpThanks = document.getElementById('rsvp-thanks');
      if (rsvpForm && rsvpThanks) {
        rsvpForm.addEventListener('submit', () => {
          // Only trigger flight if form is valid (browser-validated)
          if (!(rsvpForm as HTMLFormElement).checkValidity()) return;
          const rect = rsvpForm.getBoundingClientRect();
          const flight = document.createElement('div');
          flight.className = 'rsvp-flight';
          flight.style.left = `${rect.left + rect.width / 2 - 60}px`;
          flight.style.top = `${rect.top + rect.height / 2 - 40}px`;
          flight.innerHTML = `
            <div class="rsvp-flight-envelope">
              <div class="rsvp-flight-back"></div>
              <div class="rsvp-flight-flap"></div>
              <div class="rsvp-flight-seal"></div>
            </div>
          `;
          document.body.appendChild(flight);
          setTimeout(() => flight.remove(), 2400);
        });
      }
    </script>
  </body>
</html>
