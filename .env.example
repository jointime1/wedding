# Google Forms backing for the RSVP form.
#
# To get these values:
#   1. Build a Google Form with fields: Name, Attending, Plus-one, Picnic (optional), Note.
#   2. Click "Get pre-filled link", fill placeholder values, and inspect the URL —
#      each entry.<digits> matches one field.
#   3. The form's submit endpoint replaces "/viewform" with "/formResponse"
#      and looks like: https://docs.google.com/forms/d/e/<FORM_ID>/formResponse
#
# When PUBLIC_GOOGLE_FORM_ACTION is empty, the RSVP UI runs in preview mode:
# the form submits nothing and just shows the thank-you state.
#
# Verify the wiring with: npm run test:rsvp

PUBLIC_GOOGLE_FORM_ACTION=https://docs.google.com/forms/d/e/FORM_ID/formResponse
PUBLIC_ENTRY_NAME=entry.1111111111
PUBLIC_ENTRY_ATTENDING=entry.2222222222
PUBLIC_ENTRY_PLUS_ONE=entry.3333333333
PUBLIC_ENTRY_PICNIC=entry.4444444444
PUBLIC_ENTRY_NOTE=entry.5555555555

PUBLIC_CONTACT_DANA=+7 000 000 00 00
PUBLIC_CONTACT_ALEX=+7 000 000 00 00
